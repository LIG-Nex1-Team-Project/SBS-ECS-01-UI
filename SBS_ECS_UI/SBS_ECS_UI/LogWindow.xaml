<Window x:Class="SBS_ECS_UI.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="STM32 시스템 로그 모니터" Height="400" Width="600" Background="#121212">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="[ STM32 RAW DATA LOG ]" Foreground="Yellow" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="5" BorderBrush="#333" BorderThickness="1">
            <ListBox ItemsSource="{Binding SystemLogs}" 
                     Background="Transparent" BorderThickness="0" Foreground="LightGray">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" FontFamily="Consolas"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</Window>