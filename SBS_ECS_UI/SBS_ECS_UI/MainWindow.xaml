<Window x:Class="SBS_ECS_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SBS_ECS_UI.ViewModels"
        Title="SBS 교전통제소(ECS) UI" Height="300" Width="400">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Background="#2D2D30">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="[ 탐색기 수신 표적 제원 ]" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="X 좌표 (mm): " Foreground="LightGray" FontSize="16" Width="120"/>
                <TextBlock Text="{Binding CurrentTarget.PosX_mm}" Foreground="#4CAF50" FontSize="16" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Y 좌표 (mm): " Foreground="LightGray" FontSize="16" Width="120"/>
                <TextBlock Text="{Binding CurrentTarget.PosY_mm}" Foreground="#4CAF50" FontSize="16" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="발사대 방위각: " Foreground="LightGray" FontSize="16" Width="120"/>
                <TextBlock Text="{Binding CurrentTarget.AzimuthDegree, StringFormat={}{0:F2} °}" Foreground="#FF9800" FontSize="16" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>