<Window x:Class="SBS_ECS_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SBS_ECS_UI.ViewModels"
        Title="SBS 교전통제소(ECS) - PPI 모니터링" Height="650" Width="950">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <SolidColorBrush x:Key="RadarGreen" Color="#00FF00"/>
        <SolidColorBrush x:Key="RadarDarkGreen" Color="#004400"/>

        <Style x:Key="TargetDataStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource RadarGreen}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDanger}" Value="True">
                    <Setter Property="Foreground" Value="Red"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RangeRingStyle" TargetType="Ellipse">
            <Setter Property="Stroke" Value="{StaticResource RadarDarkGreen}"/>
            <Setter Property="StrokeThickness" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Background="#121212">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E1E" Margin="10" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="[ 시스템 제어 ]" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="Yellow" FontSize="12" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                        <UniformGrid Columns="2" Margin="0,0,0,15">
                            <Button Content="▶ 탐색 시작" Command="{Binding StartSeekerCommand}" Background="#004400" Foreground="White" Height="30" Margin="0,0,5,0"/>
                            <Button Content="■ 탐색 정지" Command="{Binding StopSeekerCommand}" Background="#440000" Foreground="White" Height="30" Margin="5,0,0,0"/>
                        </UniformGrid>

                        <Button Content="🚨 긴급 정지" Command="{Binding EmergencyStopCommand}" 
                                Background="#FF0000" Foreground="White" FontSize="16" FontWeight="Bold" Height="40" Margin="0,0,0,15">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5" BorderBrush="DarkRed" BorderThickness="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Text="전시 스케일 (px/cm)" Foreground="LightGray" FontSize="13" Margin="0,5,0,5"/>
                        <DockPanel Margin="0,0,0,15">
                            <TextBlock Text="{Binding PxPerCm, StringFormat={}{0:F1}}" Foreground="White" Width="30" DockPanel.Dock="Right" TextAlignment="Right"/>
                            <Slider Minimum="0.5" Maximum="5.0" Value="{Binding PxPerCm}" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                        </DockPanel>
                        <Separator Background="#333" Margin="0,0,0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="[ 실시간 표적 제원 ]" Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"/>
                        <UniformGrid Columns="2">
                            <TextBlock Text="X (mm):" Foreground="Gray"/>
                            <TextBlock Text="{Binding CurrentTarget.PosX_mm}" Style="{StaticResource TargetDataStyle}" HorizontalAlignment="Right"/>
                            <TextBlock Text="Y (mm):" Foreground="Gray"/>
                            <TextBlock Text="{Binding CurrentTarget.PosY_mm}" Style="{StaticResource TargetDataStyle}" HorizontalAlignment="Right"/>
                        </UniformGrid>
                        <Separator Background="#333" Margin="0,15"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="[ 적 목록 (Enemy List) ]" Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Border Background="#121212" CornerRadius="5" Height="150">
                            <ListBox ItemsSource="{Binding EnemyList}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,5,0,10">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="LimeGreen"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDanger}" Value="True">
                                                                <Setter Property="Foreground" Value="#FF4444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <StackPanel Orientation="Horizontal" Margin="2,3,0,0">
                                                <TextBlock Text="DIST: " Foreground="Gray" FontSize="11" VerticalAlignment="Bottom"/>
                                                <TextBlock Text="{Binding Distance, StringFormat={}{0:F1} mm}" Foreground="Yellow" FontSize="12" Margin="0,0,12,0"/>

                                                <TextBlock Text="AZIM: " Foreground="Gray" FontSize="11" VerticalAlignment="Bottom"/>
                                                <TextBlock Text="{Binding AzimuthDegree, StringFormat={}{0:F1}°}" Foreground="Cyan" FontSize="12"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,15,0,0">
                        <CheckBox Content="이중 안전장치 해제" IsChecked="{Binding IsDoubleSafetyChecked}" Foreground="White" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,15">
                            <Ellipse Width="12" Height="12" Fill="{Binding StatusColor}" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="White" BlurRadius="5" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="발사대 상태: " Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LauncherStatusText}" Foreground="{Binding StatusColor}" 
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Content="발사대 정렬 (ALIGN)" 
                                Command="{Binding AlignCommand}" 
                                IsEnabled="{Binding CanAlign}"
                                Background="#003366" Foreground="White" Height="40" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"/>

                        <Button Content="사격 승인 (FIRE)" 
                                Command="{Binding FireCommand}" 
                                IsEnabled="{Binding CanFire}"
                                Background="#600" Foreground="White" Height="50" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1" Margin="10">
            <Border Background="Black" CornerRadius="8" BorderBrush="{StaticResource RadarDarkGreen}" BorderThickness="2"/>

            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="500" Height="500">
                <Ellipse Style="{StaticResource RangeRingStyle}" Width="100" Height="100"/>
                <Ellipse Style="{StaticResource RangeRingStyle}" Width="200" Height="200"/>
                <Ellipse Style="{StaticResource RangeRingStyle}" Width="300" Height="300"/>
                <Ellipse Style="{StaticResource RangeRingStyle}" Width="400" Height="400"/>
                <Ellipse Stroke="Red" StrokeThickness="5" Width="100" Height="100" Opacity="0.6"/>

                <Line X1="0" Y1="250" X2="500" Y2="250" Stroke="{StaticResource RadarDarkGreen}"/>
                <Line X1="250" Y1="0" X2="250" Y2="500" Stroke="{StaticResource RadarDarkGreen}"/>

                <Canvas Width="500" Height="500">

                    <Ellipse Width="12" Height="12" Fill="Cyan" Stroke="Black" StrokeThickness="1" Margin="-6"
                             Canvas.Left="{Binding LauncherX_px}" Canvas.Top="{Binding LauncherY_px}" Panel.ZIndex="2"/>
                    <TextBlock Text="LAUNCHER" Foreground="Cyan" FontSize="10" FontWeight="Bold"
                               Canvas.Left="{Binding LauncherX_px}" Canvas.Top="{Binding LauncherY_px}" Margin="8,-6,0,0" Panel.ZIndex="2"/>

                    <Line X1="{Binding LauncherX_px}" Y1="{Binding LauncherY_px}" 
                          X2="{Binding AlignLineX2}" Y2="{Binding AlignLineY2}" 
                          Stroke="Cyan" StrokeThickness="2" StrokeDashArray="4 2"
                          Visibility="{Binding ShowAlignLine, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                          Panel.ZIndex="1"/>

                    <ContentControl Content="{Binding}" Canvas.Left="{Binding TargetX_px}" Canvas.Top="{Binding TargetY_px}" Panel.ZIndex="3">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <Canvas>
                                                <TextBlock Text="{Binding CurrentTarget.Name}" FontSize="12" FontWeight="Bold" Canvas.Left="-28" Canvas.Top="-22">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="LimeGreen"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDanger}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FF4444"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Rectangle Width="12" Height="12" Fill="Yellow" Stroke="Black" StrokeThickness="1" Margin="-6"/>
                                            </Canvas>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDanger}" Value="True">
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <Canvas>
                                                        <TextBlock Text="{Binding CurrentTarget.Name}" Foreground="#FF4444" FontSize="12" FontWeight="Bold" Canvas.Left="-28" Canvas.Top="-22"/>

                                                        <Polygon Points="0,12 6,0 12,12" Fill="Red" Stroke="White" StrokeThickness="1" Margin="-6"/>
                                                    </Canvas>
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Canvas>
            </Grid>

            <Border Background="#CCFF0000" VerticalAlignment="Top" Height="40" Margin="20" CornerRadius="20"
                    Visibility="{Binding IsDanger, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="⚠️ 위협 탐지: 위험 반경(50cm) 내 표적 진입" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
            </Border>
        </Grid>
    </Grid>
</Window>