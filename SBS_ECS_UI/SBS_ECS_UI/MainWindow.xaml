<Window x:Class="SBS_ECS_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SBS_ECS_UI.ViewModels"
        Title="SBS 교전통제소(ECS) UI" Height="450" Width="400">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="TargetDataStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4CAF50"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDanger}" Value="True">
                    <Setter Property="Foreground" Value="Red"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#2D2D30">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="[ 탐색기 수신 표적 제원 ]" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding ConnectionStatus}" Foreground="Yellow" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="X 좌표 (mm): " Foreground="LightGray" FontSize="16" Width="120"/>
                <TextBlock Text="{Binding CurrentTarget.PosX_mm}" Style="{StaticResource TargetDataStyle}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Y 좌표 (mm): " Foreground="LightGray" FontSize="16" Width="120"/>
                <TextBlock Text="{Binding CurrentTarget.PosY_mm}" Style="{StaticResource TargetDataStyle}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="발사대 방위각: " Foreground="LightGray" FontSize="16" Width="120"/>
                <TextBlock Text="{Binding CurrentTarget.AzimuthDegree, StringFormat={}{0:F2} °}" Foreground="#FF9800" FontSize="16" FontWeight="Bold"/>
            </StackPanel>

            <TextBlock Text="⚠️ 위험 영역 진입!" Foreground="Red" FontWeight="Bold" FontSize="18" Margin="0,15,0,0" HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDanger}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Separator Margin="0,20" Background="#444"/>

            <CheckBox Content="이중 안전장치 해제" 
                      IsChecked="{Binding IsDoubleSafetyChecked}" 
                      Foreground="White" HorizontalAlignment="Center" Margin="10"/>

            <Button Content="교전 시작 (FIRE)" 
                    Command="{Binding FireCommand}" 
                    Background="DarkRed" Foreground="White" 
                    Width="150" Height="40" FontSize="16" FontWeight="Bold" Margin="10"/>
        </StackPanel>
    </Grid>
</Window>